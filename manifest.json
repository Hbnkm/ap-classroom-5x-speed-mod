{
  "manifest_version": 3,
  "name": "AP Classroom 5x Speed",
  "version": "1.0.0",
  "description": "Watch AP Classroom videos at 5x speed",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "*://*.apclassroom.collegeboard.org/*",
    "*://*.collegeboard.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.apclassroom.collegeboard.org/*", "*://*.collegeboard.org/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AP Classroom 5x Speed"
  }
}
